# Production .env template — copy to .env on the server, fill in secrets, never commit.

# --- App ---------------------------------------------------------------------
APP_NAME=ProjectDesk
APP_ENV=production
APP_DEBUG=false
# Generate once with: docker run --rm $APP_IMAGE php artisan key:generate --show
APP_KEY=
APP_URL=https://projectdesk.kraupner.me
APP_DOMAIN=projectdesk.kraupner.me

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# --- Image (consumed by compose.prod.yaml) -----------------------------------
APP_IMAGE=ghcr.io/pascalkraupner/projectdesk
APP_IMAGE_TAG=latest

# --- Logging -----------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- Database (talks to the mysql service in compose.prod.yaml) --------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=projectdesk
DB_USERNAME=projectdesk
DB_PASSWORD=
DB_ROOT_PASSWORD=

# --- Session / cache / queue -------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- Mail (log driver until real SMTP is wired up) ---------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@projectdesk.kraupner.me"
MAIL_FROM_NAME="${APP_NAME}"

# --- Seeded admin user (consumed by the create_users_table migration) --------
ADMIN_PASSWORD=

# --- Vite build-time vars ----------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
